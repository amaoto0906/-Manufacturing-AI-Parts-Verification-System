# ===== 部品照合システム 環境設定サンプル =====
# 実運用では .env にコピーし、現場条件に合わせて調整する。

# --- 特徴抽出バックボーン: classic | torchvision | dinov2 ---
# classic     : numpy/PIL のみ。GPU不要・追加DLなし（PoC/フォールバック既定）
# torchvision : ResNet/MobileNet の汎用特徴抽出（torch必要・重み自動DL）
# dinov2      : 本番推奨。基盤モデル DINOv2 ViT（torch + torch.hub 重みDL）
PARTMATCH_BACKEND=classic
PARTMATCH_TORCHVISION_ARCH=mobilenet_v3_small
PARTMATCH_DINOV2_ARCH=dinov2_vits14

# --- 投影ヘッド（Metric Learning）---
PARTMATCH_PROJECTION_DIM=256
PARTMATCH_USE_PROJECTION=true

# --- 判定しきい値（安全側設計の中核）---
# 受理: コサイン類似度がこの値以上で OK 候補
PARTMATCH_ACCEPT_THRESHOLD=0.62
# 要確認: この値以上〜accept未満は REVIEW
PARTMATCH_REVIEW_THRESHOLD=0.45
# Top1 と Top2 の差。小さいと曖昧 → REVIEW
PARTMATCH_MARGIN_THRESHOLD=0.06
# Top2 が Top1 と同一「類似品番グループ」の場合に要求する追加マージン
PARTMATCH_SIMILAR_MARGIN_THRESHOLD=0.10

# --- 検索 ---
PARTMATCH_TOP_K=5

# --- パス ---
PARTMATCH_DATA_DIR=./var/data
PARTMATCH_MODELS_DIR=./var/models
PARTMATCH_DB_PATH=./var/partmatch.db
PARTMATCH_INDEX_PATH=./var/models/index.faiss

# --- 推論 ---
PARTMATCH_DEVICE=cpu
PARTMATCH_IMAGE_SIZE=224

# --- 画質しきい値（scripts/40_calibrate_quality.py --save で生成・自動適用）---
PARTMATCH_QUALITY_THRESHOLDS_PATH=./var/models/quality_thresholds.json
